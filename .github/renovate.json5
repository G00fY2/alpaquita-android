{
    $schema: 'https://docs.renovatebot.com/renovate-schema.json',
    extends: [
        'config:best-practices',
    ],
    automerge: true,
    customManagers: [
        {
            customType: 'regex',
            managerFilePatterns: [
                '.github/workflows/*.yaml',
            ],
            matchStrings: [
                'DOCKER_BUILDX_VERSION:\\s*(?<currentValue>.*)',
            ],
            depNameTemplate: 'docker/buildx',
            datasourceTemplate: 'github-releases',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '.github/workflows/*.yaml',
            ],
            matchStrings: [
                'DOCKER_BUILDKIT_VERSION:\\s*(?<currentValue>.*)',
            ],
            depNameTemplate: 'moby/buildkit',
            datasourceTemplate: 'github-releases',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '.github/workflows/*.yaml',
            ],
            matchStrings: [
                'DIVE_VERSION:\\s*(?<currentValue>.*)',
            ],
            depNameTemplate: 'wagoodman/dive',
            datasourceTemplate: 'github-releases',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '.github/workflows/*.yaml',
            ],
            matchStrings: [
                'ACTIONLINT_VERSION:\\s*(?<currentValue>.*)',
            ],
            depNameTemplate: 'rhysd/actionlint',
            datasourceTemplate: 'github-releases',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '.github/workflows/*.yaml',
            ],
            matchStrings: [
                'YAMLLINT_VERSION:\\s*(?<currentValue>.*)',
            ],
            depNameTemplate: 'yamllint',
            datasourceTemplate: 'pypi',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '/versions\\.env$/',
            ],
            matchStrings: [
                'ANDROID_CMDLINE_TOOLS_VERSION=(?<currentValue>.*)',
            ],
            depNameTemplate: 'android_cmdline_tools',
            datasourceTemplate: 'custom.android_cmdline_tools',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '/versions\\.env$/',
            ],
            matchStrings: [
                'ANDROID_PLATFORM_TOOLS_VERSION=(?<currentValue>.*)',
            ],
            depNameTemplate: 'android_platform_tools',
            datasourceTemplate: 'custom.android_platform_tools',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '/versions\\.env$/',
            ],
            matchStrings: [
                'ANDROID_BUILD_TOOLS_VERSION=(?<currentValue>.*)',
            ],
            depNameTemplate: 'android_build_tools',
            datasourceTemplate: 'custom.android_build_tools',
        },
        {
            customType: 'regex',
            managerFilePatterns: [
                '/versions\\.env$/',
            ],
            matchStrings: [
                'ANDROID_PLATFORM_LATEST_VERSION=(?<currentValue>.*)',
            ],
            depNameTemplate: 'android_platform_version',
            datasourceTemplate: 'custom.android_platform_version',
        },
    ],
    customDatasources: {
        android_cmdline_tools: {
            defaultRegistryUrlTemplate: 'https://dl.google.com/android/repository/repository2-1.xml',
            format: 'plain',
            transformTemplates: [
                'releases[$contains(version, "cmdline-tools;")].version',
                '$map($, function($v) { $replace($v, /.*cmdline-tools;([^"]+).*/, "$1") })',
                '{"releases": $map($, function($v) { {"version": $v} })}',
            ],
        },
        android_platform_tools: {
            defaultRegistryUrlTemplate: 'https://dl.google.com/android/repository/repository2-1.xml',
            format: 'plain',
            transformTemplates: [
                'releases[$contains(version, "platform-tools_r")].version',
                '$map($, function($v) { $replace($v, /.*platform-tools_r([^-]+)-linux.*/, "$1") })',
                '{"releases": $map($, function($v) { {"version": $v} })}',
            ],
        },
        android_build_tools: {
            defaultRegistryUrlTemplate: 'https://dl.google.com/android/repository/repository2-1.xml',
            format: 'plain',
            transformTemplates: [
                'releases[$contains(version, "build-tools;")].version',
                '$map($, function($v) { $replace($v, /.*build-tools;([^"]+).*/, "$1") })',
                '{"releases": $map($, function($v) { {"version": $v} })}',
            ],
        },
        android_platform_version: {
            defaultRegistryUrlTemplate: 'https://dl.google.com/android/repository/repository2-3.xml',
            format: 'plain',
            transformTemplates: [
                'releases[$contains(version, "platforms;android-")].version',
                '$map($, function($v) { $replace($v, /.*platforms;android-([^"]+).*/, "$1") })',
                '{"releases": $map($, function($v) { {"version": $v} })}',
            ],
        },
    },
    packageRules: [
        {
            description: 'Group Android SDK updates and wait for minimumReleaseAge to update in sync (Minor Release)',
            matchPackageNames: [
                'android_cmdline_tools',
                'android_platform_tools',
                'android_build_tools',
                'android_platform_version',
            ],
            groupName: 'android sdk components',
            minimumReleaseAge: '1 days',
            prCreation: 'not-pending',
            semanticCommitType: 'feat',
        },
        {
            description: 'Group Liberica JDK images and wait for minimumReleaseAge to update in sync (Patch Release)',
            matchPackageNames: [
                'ghcr.io/bell-sw/liberica-runtime-container',
            ],
            groupName: 'liberica jdk container',
            minimumReleaseAge: '7 days',
            prCreation: 'not-pending',
            semanticCommitType: 'fix',
        },
        {
            description: 'Dockerfile Syntax updates (No Release)',
            matchPackageNames: [
                'docker/dockerfile',
            ],
            semanticCommitType: 'ci',
        },
        {
            description: 'CI & Linter updates (No Release)',
            matchManagers: [
                'github-actions',
            ],
            semanticCommitType: 'ci',
        },
        {
            description: 'Linter updates from Workflows (No Release)',
            matchPackageNames: [
                'docker/buildx',
                'moby/buildkit',
                'wagoodman/dive',
                'rhysd/actionlint',
                'yamllint',
            ],
            semanticCommitType: 'ci',
        },
    ],
}
